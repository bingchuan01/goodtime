page {
  min-height: 100vh;
  background: #f5f5f5;
}

.search-page {
  height: 100vh;
  padding: 24rpx 30rpx;
  padding-top: calc(var(--status-bar-height, 44rpx) + 88rpx);
  box-sizing: border-box;
}

/* 搜索输入框 */
.search-input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.input-wrap {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 32rpx;
  padding: 0 24rpx;
  height: 72rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
}

.clear-btn {
  font-size: 40rpx;
  color: #999;
  padding: 0 8rpx;
}

.search-btn {
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #FF6B35 0%, #f7931e 100%);
  border-radius: 36rpx;
}

/* 智能联想 */
.suggestion-panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.suggestion-item {
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}

.suggestion-item:active {
  background: #f5f5f5;
  border-radius: 8rpx;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-action {
  font-size: 26rpx;
  color: #999;
}

/* 搜索历史 */
.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

.history-text {
  margin-right: 8rpx;
}

.history-del {
  color: #999;
  font-size: 32rpx;
  padding: 0 4rpx;
}

/* 筛选芯片 */
.filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 32rpx;
}

.chip.active {
  color: #FF6B35;
  background: rgba(255, 107, 53, 0.12);
}

/* 当前筛选条件标签 */
.filter-tags-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: #FF6B35;
  background: rgba(255, 107, 53, 0.1);
  border-radius: 8rpx;
}

.tag-close {
  margin-left: 8rpx;
  font-size: 28rpx;
}

.clear-all {
  font-size: 24rpx;
  color: #999;
}

.section-inline {
  margin-bottom: 24rpx;
}

/* 搜索结果 */
.result-area {
  min-height: 200rpx;
}

.loading, .empty {
  text-align: center;
  padding: 60rpx;
  font-size: 28rpx;
  color: #999;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
