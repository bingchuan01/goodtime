page {
  height: 100%;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.page-container {
  height: 100vh;
  box-sizing: border-box;
  padding-top: var(--status-bar-height, 44rpx);
  padding-bottom: 220rpx;
}

/* ========== 通用卡片 ========== */
.card {
  margin: 0 30rpx 24rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 提示词 + 权益说明 */
.card-intro {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.intro-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.intro-link {
  display: flex;
  align-items: center;
  color: #667eea;
  font-size: 28rpx;
}

.arrow {
  margin-left: 8rpx;
}

/* ========== V6 / V8 套餐卡片 ========== */
.card-plans {
  padding: 24rpx;
}

.plan-row {
  display: flex;
  gap: 24rpx;
}

.plan-card {
  flex: 1;
  position: relative;
  padding: 28rpx;
  border-radius: 16rpx;
  min-height: 180rpx;
}

.plan-v6 {
  background: #fef9e7;
  border: 2rpx solid #f1c40f;
}

.plan-v8 {
  background: #e8e8e8;
  border: 2rpx solid #bdc3c7;
}

.plan-card.selected.plan-v6 {
  background: #fdeaa0;
  border-color: #f39c12;
}

.plan-card.selected.plan-v8 {
  background: #d5d8dc;
  border-color: #7f8c8d;
}

.plan-tag {
  position: absolute;
  top: 12rpx;
  left: 16rpx;
  font-size: 22rpx;
  font-weight: bold;
  color: #c0392b;
}

.plan-duration {
  font-size: 24rpx;
  color: #666;
  margin-top: 32rpx;
  margin-bottom: 12rpx;
}

.plan-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.plan-price .unit {
  font-size: 24rpx;
  font-weight: normal;
  color: #666;
}

/* ========== 选择支付方式 ========== */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.payment-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.payment-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.payment-item:last-child {
  border-bottom: none;
}

.radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  margin-right: 24rpx;
}

.radio.checked {
  border-color: #e74c3c;
  background: #e74c3c;
  box-sizing: border-box;
}

.payment-name {
  font-size: 28rpx;
  color: #333;
}

/* ========== 购买须知 ========== */
.card-notice .notice-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* ========== 底部占位 ========== */
.bottom-placeholder {
  height: 40rpx;
}

/* ========== 底部：协议 + 确认支付 ========== */
.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.agreement-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.checkbox-wrap {
  margin-right: 8rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 2rpx solid #ccc;
}

.checkbox.checked {
  background: #e74c3c;
  border-color: #e74c3c;
}

.agreement-text {
  font-size: 24rpx;
  color: #666;
}

.agreement-link {
  font-size: 24rpx;
  color: #667eea;
  text-decoration: underline;
}

.v8-hint {
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #e67e22;
  text-align: center;
}

/* 按钮两行显示：缩进行距，完整展示「确认协议并支付」+ 金额 */
.btn-pay {
  width: 100%;
  min-height: 88rpx;
  padding: 16rpx 24rpx;
  line-height: 1.35;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
  border-radius: 44rpx;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.btn-pay .btn-pay-text {
  display: block;
  line-height: 1.4;
}

.btn-pay .btn-pay-amount {
  display: block;
  font-size: 32rpx;
  margin-top: 4rpx;
}

.btn-pay[disabled] {
  background: #e0e0e0;
  color: #999;
}

.btn-pay::after {
  border: none;
}
