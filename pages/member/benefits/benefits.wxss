page {
  height: 100%;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 给 scroll-view 明确高度，避免 Skyline 下 flex 不生效导致白屏 */
.page-container {
  height: 100vh;
  box-sizing: border-box;
  padding-top: var(--status-bar-height, 44rpx);
  padding-bottom: 140rpx;
}

/* ========== 用户信息卡片 ========== */
.user-card {
  display: flex;
  align-items: center;
  margin: 0 30rpx 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.avatar-wrap {
  margin-right: 24rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #eee;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
  border: 2rpx solid #e0e0e0;
}

.user-meta {
  flex: 1;
}

.nickname {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.member-status {
  font-size: 24rpx;
  color: #999;
}

.btn-open {
  padding: 0 36rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  background: #e74c3c;
  border-radius: 32rpx;
  border: none;
}

.btn-open::after {
  border: none;
}

/* ========== 会员权益宫格 ========== */
.section {
  margin: 0 30rpx 24rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.section-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 28rpx;
}

/* 真机兼容：用 flex 四列宫格替代 grid */
.benefits-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.benefit-cell {
  width: 25%;
  box-sizing: border-box;
  padding: 12rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.benefit-icon {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 36rpx;
  margin-bottom: 12rpx;
  color: #ccc;
  border-radius: 50%;
  background: #f5f5f5;
}

.benefit-icon.enabled {
  color: #e74c3c;
  background: rgba(231, 76, 60, 0.1);
}

.benefit-name {
  font-size: 22rpx;
  color: #666;
  line-height: 1.3;
}

/* ========== 成为他们：横向滑动封面，真机可见并排与滑动 ========== */
.section-them {
  padding-bottom: 40rpx;
}

.section-them .carousel-wrap {
  position: relative;
  margin: 0 -30rpx 0;
  padding: 24rpx 0 56rpx;
  border-radius: 0 0 20rpx 20rpx;
  min-height: 320rpx;
}

.carousel-glass {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 0 0 20rpx 20rpx;
}

/* 横向 scroll-view 必须设固定高度，真机才能正确显示并排项 */
.carousel-scroll {
  position: relative;
  width: 100%;
  height: 300rpx;
  z-index: 1;
}

.carousel-track {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 300rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.carousel-item {
  flex-shrink: 0;
  width: 280rpx;
  height: 260rpx;
  margin-right: 24rpx;
  box-sizing: border-box;
}

.carousel-item:last-child {
  margin-right: 24rpx;
}

.carousel-item .carousel-card {
  width: 100%;
  height: 220rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  position: relative;
}

.carousel-image {
  width: 100%;
  height: 100%;
  display: block;
}

.carousel-placeholder {
  width: 100%;
  height: 100%;
  line-height: 220rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
}

.carousel-item.active .carousel-card {
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.12);
  color: #333;
}

.carousel-dots {
  position: absolute;
  bottom: 16rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 12rpx;
  z-index: 2;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.2);
  transition: all 0.2s ease;
}

.dot.active {
  width: 24rpx;
  border-radius: 6rpx;
  background: rgba(102, 126, 234, 0.9);
}

/* ========== 底部占位：留足空间，避免成为他们被吸底按钮挡住 ========== */
.bottom-placeholder {
  height: 120rpx;
}

/* ========== 吸底立即开通 ========== */
.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  transform: translateY(100%);
  transition: transform 0.25s ease;
}

.footer-bar.show {
  transform: translateY(0);
}

.btn-footer {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 44rpx;
  border: none;
}

.btn-footer::after {
  border: none;
}
