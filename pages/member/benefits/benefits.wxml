<!--会员权益页（会员中心）-->
<navigation-bar title="会员中心" back="{{false}}" color="white" background="linear-gradient(135deg, rgba(230,180,220,0.95) 0%, rgba(180,160,220,0.95) 100%)"></navigation-bar>

<scroll-view class="page-container" scroll-y="{{true}}" bindscroll="onScroll" bindscrolltolower="onScrollToLower">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar-wrap">
      <image wx:if="{{userInfo && userInfo.avatarUrl}}" class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <view wx:else class="avatar avatar-placeholder">头像</view>
    </view>
    <view class="user-meta">
      <view class="nickname">{{userInfo && userInfo.nickname ? userInfo.nickname : '未设置昵称'}}</view>
      <view class="member-status" wx:if="{{isMember}}">会员有效期至 {{memberExpireText}}</view>
      <view class="member-status" wx:else>尚未开通</view>
    </view>
    <button class="btn-open" bindtap="goUpgrade" wx:if="{{isMember}}">续费/升级会员</button>
    <button class="btn-open" bindtap="goUpgrade" wx:else>立即开通</button>
  </view>

  <!-- 会员权益：宫格，红翅膀=可享 -->
  <view class="section section-benefits">
    <view class="section-title">会员权益</view>
    <view class="section-desc">红色天使翅膀代表会员可享权益</view>
    <view class="benefits-grid">
      <view class="benefit-cell" wx:for="{{benefitsList}}" wx:key="id">
        <view class="benefit-icon {{item.enabled ? 'enabled' : ''}}">{{item.icon}}</view>
        <text class="benefit-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 成为他们：层叠轮播 8 张 -->
  <view class="section section-them">
    <view class="section-title">成为他们</view>
    <view class="section-desc">再小的生意 也有自己的品牌</view>
    <view class="carousel-wrap" style="background: {{carouselBg}};">
      <view class="carousel-glass"></view>
      <scroll-view
        class="carousel-scroll"
        scroll-x="{{true}}"
        enable-flex="{{true}}"
        scroll-with-animation
        scroll-left="{{carouselScrollLeft}}"
        bindscroll="onCarouselScroll"
      >
        <view class="carousel-track">
          <view
            class="carousel-item {{carouselIndex === index ? 'active' : ''}}"
            wx:for="{{carouselList}}"
            wx:key="id"
            data-index="{{index}}"
            bindtap="onCarouselTap"
          >
            <view class="carousel-card">
              <image wx:if="{{item.cover}}" class="carousel-image" src="{{item.cover}}" mode="aspectFill" />
              <view wx:else class="carousel-placeholder">{{item.title}}</view>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="carousel-dots">
        <view
          class="dot {{carouselIndex === index ? 'active' : ''}}"
          wx:for="{{carouselList}}"
          wx:key="id"
          data-index="{{index}}"
          bindtap="onCarouselDotTap"
        ></view>
      </view>
    </view>
  </view>

  <!-- 底部占位，避免被吸底按钮遮挡 -->
  <view class="bottom-placeholder"></view>
</scroll-view>

<!-- 吸底：立即开通会员 -->
<view class="footer-bar {{showFooterBar ? 'show' : ''}}">
  <button class="btn-footer" bindtap="goUpgrade" wx:if="{{isMember}}">续费/升级会员</button>
  <button class="btn-footer" bindtap="goUpgrade" wx:else>立即开通会员</button>
</view>
