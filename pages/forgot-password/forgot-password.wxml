<!--忘记密码页-->
<navigation-bar title="忘记密码" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="scrollarea" scroll-y="true">
  <!-- 头部区域：欢迎语+平台LOGO -->
  <header-logo logo-url="/images/hsjlogo.png"></header-logo>
  
  <view class="container">
    <!-- 步骤指示器 -->
    <view class="step-indicator">
      <view class="step-item {{step >= 1 ? 'active' : ''}} {{step > 1 ? 'completed' : ''}}">
        <view class="step-number">1</view>
        <view class="step-label">输入手机号</view>
      </view>
      <view class="step-line {{step > 1 ? 'active' : ''}}"></view>
      <view class="step-item {{step >= 2 ? 'active' : ''}} {{step > 2 ? 'completed' : ''}}">
        <view class="step-number">2</view>
        <view class="step-label">输入新密码</view>
      </view>
      <view class="step-line {{step > 2 ? 'active' : ''}}"></view>
      <view class="step-item {{step >= 3 ? 'active' : ''}} {{step > 3 ? 'completed' : ''}}">
        <view class="step-number">3</view>
        <view class="step-label">输入验证码</view>
      </view>
      <view class="step-line {{step > 3 ? 'active' : ''}}"></view>
      <view class="step-item {{step >= 4 ? 'active' : ''}}">
        <view class="step-number">4</view>
        <view class="step-label">确认修改</view>
      </view>
    </view>

    <!-- 表单容器 -->
    <view class="form-container">
      <!-- 第一步：输入手机号 -->
      <view class="form-content" wx:if="{{step === 1}}">
        <view class="form-title">请输入手机号</view>
        <view class="input-group">
          <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
        </view>
        <button class="submit-btn" bindtap="nextStep" disabled="{{!phone}}">下一步</button>
      </view>

      <!-- 第二步：输入新密码 -->
      <view class="form-content" wx:if="{{step === 2}}">
        <view class="form-title">请输入新密码</view>
        <view class="input-group">
          <input class="input" type="{{showPassword ? 'text' : 'password'}}" placeholder="请输入新密码（至少6位）" value="{{password}}" bindinput="onPasswordInput" />
          <view class="eye-icon" bindtap="togglePassword">
            <text>{{showPassword ? '👁️' : '👁️‍🗨️'}}</text>
          </view>
        </view>
        <view class="input-group">
          <input class="input" type="{{showPasswordConfirm ? 'text' : 'password'}}" placeholder="请确认新密码" value="{{passwordConfirm}}" bindinput="onPasswordConfirmInput" />
          <view class="eye-icon" bindtap="togglePasswordConfirm">
            <text>{{showPasswordConfirm ? '👁️' : '👁️‍🗨️'}}</text>
          </view>
        </view>
        <view class="btn-group">
          <button class="back-btn" bindtap="prevStep">上一步</button>
          <button class="submit-btn" bindtap="nextStep" disabled="{{!password || !passwordConfirm || password !== passwordConfirm}}">下一步</button>
        </view>
      </view>

      <!-- 第三步：输入验证码 -->
      <view class="form-content" wx:if="{{step === 3}}">
        <view class="form-title">请输入验证码</view>
        <view class="phone-tip">验证码已发送至 {{phone}}</view>
        <view class="input-group">
          <input class="input" type="number" placeholder="请输入6位验证码" value="{{code}}" bindinput="onCodeInput" maxlength="6" />
          <button class="code-btn {{codeCountdown > 0 ? 'disabled' : ''}}" bindtap="onGetCode" disabled="{{codeCountdown > 0}}">
            {{codeCountdown > 0 ? codeCountdown + 's' : '重新获取'}}
          </button>
        </view>
        <view class="btn-group">
          <button class="back-btn" bindtap="prevStep">上一步</button>
          <button class="submit-btn" bindtap="nextStep" disabled="{{!code || code.length !== 6}}">下一步</button>
        </view>
      </view>

      <!-- 第四步：确认修改 -->
      <view class="form-content" wx:if="{{step === 4}}">
        <view class="form-title">确认修改密码</view>
        <view class="confirm-info">
          <view class="info-item">
            <text class="label">手机号：</text>
            <text class="value">{{phone}}</text>
          </view>
          <view class="info-item">
            <text class="label">新密码：</text>
            <text class="value">••••••</text>
          </view>
        </view>
        <view class="btn-group">
          <button class="back-btn" bindtap="prevStep">上一步</button>
          <button class="submit-btn" bindtap="onConfirm" loading="{{loading}}" disabled="{{loading}}">确认修改</button>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
