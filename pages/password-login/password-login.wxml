<!--账号密码登录页-->
<navigation-bar title="" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="scrollarea" scroll-y="true">
  <!-- 头部区域：欢迎语+平台LOGO -->
  <header-logo logo-url="/images/hsjlogo.png"></header-logo>
  <view class="welcome-text">欢迎使用好时机商业品牌小程序</view>
  
  <view class="container">
    <!-- 页面标题 -->
    <view class="page-title">账号密码登录</view>
    <view class="title-divider"></view>

    <!-- 表单容器 -->
    <view class="form-container">
      <!-- 账号输入框 -->
      <view class="input-group">
        <view class="input-label">账号</view>
        <input class="input" type="text" placeholder="请输入手机号码或邮箱" value="{{account}}" bindinput="onAccountInput" />
      </view>

      <!-- 密码输入框 -->
      <view class="input-group password-input-group">
        <view class="input-label">密码</view>
        <input class="input password-input" type="{{showPassword ? 'text' : 'password'}}" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
        <text class="forgot-password-link" bindtap="goToForgotPassword">忘记密码</text>
      </view>

      <!-- 登录按钮 -->
      <button class="submit-btn" bindtap="onPasswordLogin" disabled="{{!account || !password || !agreed}}">登录</button>

      <!-- 切换到手机短信登录 -->
      <view class="switch-login">
        <text class="switch-link" bindtap="goToPhoneLogin">手机短信登录 ></text>
      </view>

      <!-- 微信一键登录 -->
      <button class="wx-login-btn" bindtap="onWxLogin" loading="{{loading}}" disabled="{{loading || !agreed}}">
        <text class="wx-icon-text">💬</text>
        <text>微信一键登录</text>
      </button>
    </view>

    <!-- 协议勾选 -->
    <view class="agreement-section">
      <checkbox-group bindchange="onAgreementChange">
        <label class="agreement-label">
          <checkbox value="agree" checked="{{agreed}}" class="agreement-checkbox" />
          <view class="agreement-content">
            <text class="agreement-text">我已阅读并同意<text class="link" bindtap="goToAgreement" data-type="user">用户协议</text>、<text class="link" bindtap="goToAgreement" data-type="privacy">隐私政策</text>，完成手机号验证成功后将自动注册</text>
          </view>
        </label>
      </checkbox-group>
    </view>
  </view>
</scroll-view>
