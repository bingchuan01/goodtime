<!--编辑资料-->
<navigation-bar title="编辑资料" back="{{true}}" color="black" background="#FFF"></navigation-bar>

<scroll-view class="container" scroll-y>
  <view class="form-section">
    <view class="form-item">
      <view class="label">头像</view>
      <view class="avatar-section" bindtap="chooseAvatar">
        <image class="avatar" src="{{avatarUrl || '/images/icons/default-avatar.svg'}}" mode="aspectFill"></image>
        <text class="avatar-tip">点击更换</text>
      </view>
    </view>

    <view class="form-item">
      <view class="label">昵称</view>
      <input 
        class="input" 
        placeholder="请输入昵称" 
        value="{{nickname}}"
        bindinput="onNicknameInput"
        maxlength="20"
      />
    </view>
  </view>

  <view class="footer">
    <button class="save-btn" bindtap="onSave">保存</button>
  </view>
</scroll-view>
