page {
  background-color: #f5f5f5;
}

.container {
  height: 100vh;
  padding-top: var(--status-bar-height, 44rpx);
  padding-bottom: 120rpx;
}

.form-section {
  background-color: #fff;
  margin: 30rpx;
  border-radius: 10rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.avatar-tip {
  font-size: 24rpx;
  color: #999;
}

.input {
  width: 100%;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #1296db;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
  font-weight: bold;
}
