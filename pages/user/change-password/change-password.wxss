page {
  background-color: #f5f5f5;
}

.container {
  height: 100vh;
  padding-top: var(--status-bar-height, 44rpx);
  padding-bottom: 120rpx;
}

.form-section {
  background-color: #fff;
  margin: 30rpx;
  border-radius: 10rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
}

.input {
  flex: 1;
  padding: 24rpx 0;
  font-size: 28rpx;
}

.toggle-btn {
  font-size: 24rpx;
  color: #1296db;
  padding: 10rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #1296db;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
  font-weight: bold;
}
