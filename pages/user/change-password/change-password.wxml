<!--修改登录密码-->
<navigation-bar title="修改登录密码" back="{{true}}" color="black" background="#FFF"></navigation-bar>

<scroll-view class="container" scroll-y>
  <view class="form-section">
    <view class="form-item">
      <view class="label">原密码</view>
      <view class="input-wrap">
        <input 
          class="input" 
          type="{{showOld ? 'text' : 'password'}}"
          placeholder="请输入原密码"
          value="{{oldPassword}}"
          bindinput="onOldInput"
        />
        <text class="toggle-btn" bindtap="toggleOld">{{showOld ? '隐藏' : '显示'}}</text>
      </view>
    </view>
    <view class="form-item">
      <view class="label">新密码</view>
      <view class="input-wrap">
        <input 
          class="input" 
          type="{{showNew ? 'text' : 'password'}}"
          placeholder="请输入新密码（至少6位）"
          value="{{newPassword}}"
          bindinput="onNewInput"
        />
        <text class="toggle-btn" bindtap="toggleNew">{{showNew ? '隐藏' : '显示'}}</text>
      </view>
    </view>
    <view class="form-item">
      <view class="label">确认新密码</view>
      <view class="input-wrap">
        <input 
          class="input" 
          type="{{showConfirm ? 'text' : 'password'}}"
          placeholder="请再次输入新密码"
          value="{{confirmPassword}}"
          bindinput="onConfirmInput"
        />
        <text class="toggle-btn" bindtap="toggleConfirm">{{showConfirm ? '隐藏' : '显示'}}</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <button class="submit-btn" bindtap="onSubmit">确认修改</button>
  </view>
</scroll-view>
