<!-- MVP 版个人中心 -->
<navigation-bar title="个人中心" back="{{false}}" color="black" background="#FFF"></navigation-bar>

<scroll-view class="container" scroll-y>
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-header">
      <view class="avatar-wrap" bindtap="editProfile">
        <image wx:if="{{userInfo && (userInfo.avatarUrl || userInfo.avatar_url)}}" class="avatar" src="{{userInfo.avatarUrl || userInfo.avatar_url}}" mode="aspectFill"></image>
        <view wx:else class="avatar avatar-placeholder">头像</view>
      </view>
      <view class="user-info">
        <view class="nickname">{{userInfo && userInfo.nickname ? userInfo.nickname : '未设置昵称'}}</view>
        <view class="user-id">ID: {{userInfo && userInfo.id ? userInfo.id : '--'}}</view>
      </view>
      <view class="edit-btn" bindtap="editProfile">编辑</view>
    </view>
    
    <!-- MVP 统计数据：发布数、获赞、播放 -->
    <view class="stats">
      <view class="stat-item" bindtap="myProjects">
        <text class="stat-value">{{stats.projectCount}}</text>
        <text class="stat-label">发布</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.likeCount}}</text>
        <text class="stat-label">获赞</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.viewCount}}</text>
        <text class="stat-label">播放</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="myProjects">
      <text class="menu-icon">📋</text>
      <text class="menu-text">我的发布</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goMessages">
      <text class="menu-icon">✉️</text>
      <text class="menu-text">站内信</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="memberCenter">
      <text class="menu-icon">👑</text>
      <text class="menu-text">会员权益</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</scroll-view>






