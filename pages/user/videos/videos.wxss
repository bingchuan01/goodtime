.page {
  background: #f5f5f5;
}

.status-tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx 20rpx;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
}

.tab.active {
  color: #FF6B35;
  font-weight: bold;
}

.container {
  height: calc(100vh - 120rpx);
  padding: 20rpx;
}

.project-list {
  padding-bottom: 40rpx;
}

.project-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.project-item.clickable {
  cursor: pointer;
}

.cover-wrap {
  position: relative;
  width: 220rpx;
  height: 124rpx;
  flex-shrink: 0;
}

.cover {
  width: 100%;
  height: 100%;
  background: #eee;
}

.status-tag {
  position: absolute;
  bottom: 8rpx;
  left: 8rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  border-radius: 8rpx;
  color: #fff;
}

.status-tag.status-approved {
  background: #07c160;
}

.status-tag.status-rejected {
  background: #fa9d3b;
}

.status-tag.status-pending {
  background: #576b95;
}

.info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.reject-reason {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
}

.reason-label {
  color: #666;
}

.reason-text {
  color: #fa9d3b;
}

.actions {
  margin-top: 12rpx;
}

.btn-edit {
  display: inline-block;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #FF6B35;
  border: 1rpx solid #FF6B35;
  border-radius: 8rpx;
  background: #fff;
}

.link-tip {
  font-size: 22rpx;
  color: #999;
}

.loading,
.no-more,
.empty {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999;
}

.empty {
  padding: 120rpx 40rpx;
}
