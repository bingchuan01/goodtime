page {
  background-color: #f5f5f5;
}

.container {
  height: 100vh;
  padding-top: var(--status-bar-height, 44rpx);
  padding-bottom: 60rpx;
}

.menu-section {
  background-color: #fff;
  margin: 30rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-disabled {
  opacity: 0.6;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-text-danger {
  color: #ff4444;
  font-weight: 500;
}

.menu-arrow {
  font-size: 24rpx;
  color: #999;
  margin-left: 10rpx;
}

.menu-extra {
  font-size: 24rpx;
  color: #999;
  margin-right: 10rpx;
}

.menu-tag {
  font-size: 22rpx;
  color: #999;
}

.danger-section {
  margin-top: 20rpx;
}
