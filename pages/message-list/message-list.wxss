/* 站内信列表页，与首页风格一致 */
page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  height: 0;
}

.compose-bar {
  padding: 20rpx 20rpx 0;
  margin-bottom: 10rpx;
}

.compose-btn {
  background-color: #FF6B35;
  color: #fff;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.list-section {
  padding: 20rpx;
}

.msg-card {
  display: flex;
  align-items: flex-start;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  position: relative;
}

.msg-card .avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.msg-card .main {
  flex: 1;
  min-width: 0;
}

.msg-card .row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.msg-card .name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.msg-card .time {
  font-size: 22rpx;
  color: #999;
}

.msg-card .subject {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.msg-card .preview {
  display: block;
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.msg-card .dot {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #FF6B35;
}

.loading-more,
.no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 80rpx 30rpx;
  font-size: 28rpx;
  color: #999;
}
