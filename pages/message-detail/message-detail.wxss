/* 站内信详情页，与首页风格一致 */
page {
  min-height: 100%;
  background-color: #f5f5f5;
}

.page-wrap {
  padding: 20rpx;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
}

.sender-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.sender-card .avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background-color: #f5f5f5;
}

.sender-card .meta {
  flex: 1;
}

.sender-card .name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.sender-card .time {
  font-size: 22rpx;
  color: #999;
}

.content-card {
  padding: 24rpx;
}

.content-card .subject {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.content-card .body {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.actions .btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.actions .btn.primary {
  background-color: #FF6B35;
  color: #fff;
}

.actions .btn.danger {
  background-color: #fff;
  color: #999;
  border: 1rpx solid #e0e0e0;
}

.loading-wrap {
  padding: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}
