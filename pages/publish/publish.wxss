/* 项目发布页样式 */
page {
  background-color: #f5f5f5;
}

.container {
  height: 100vh;
  padding-top: var(--status-bar-height, 44rpx);
  padding-bottom: 220rpx;
}

/* 发布类型Tab */
.publish-type-tabs {
  display: flex;
  background-color: #fff;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 32rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #FF6B35;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background-color: #FF6B35;
}

/* 上传方式Tab（V8高级发布） */
.upload-type-tabs {
  display: flex;
  gap: 20rpx;
}

.upload-tab {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
}

.upload-tab.active {
  background-color: #FF6B35;
  color: #fff;
}

/* 表单区域 */
.section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
  box-sizing: border-box;
  max-width: 100%;
}

/* 门店、IP 容器：宽度限制在屏幕内 */
.section-store-ip {
  width: 100%;
  max-width: 100vw;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #ff4444;
  margin-right: 4rpx;
}

.section-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.link-text {
  color: #1296db;
  text-decoration: underline;
}

/* 表单输入 */
.form-input {
  width: 100%;
  max-width: 100%;
  min-height: 88rpx;
  padding: 24rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  max-width: 100%;
  min-height: 200rpx;
  padding: 24rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  box-sizing: border-box;
}

/* 轮播图上传区域 */
.carousel-upload-area {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.carousel-item {
  width: calc(50% - 10rpx);
  aspect-ratio: 16 / 9;
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
}

.carousel-image {
  width: 100%;
  height: 100%;
}

.carousel-actions {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 10rpx;
  padding: 10rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
}

.action-btn {
  flex: 1;
  padding: 8rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 4rpx;
  text-align: center;
  font-size: 22rpx;
  color: #333;
}

.action-btn.active {
  background-color: #FF6B35;
  color: #fff;
}

.action-btn.delete {
  background-color: rgba(255, 68, 68, 0.9);
  color: #fff;
}

.upload-btn {
  background-color: #f5f5f5;
  border: 2rpx dashed #ddd;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 60rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #666;
}

/* 视频上传区域 */
.video-upload-area {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.video-upload-btn {
  width: 100%;
  height: 400rpx;
  background-color: #f5f5f5;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.video-preview {
  position: relative;
}

.preview-video {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
  background-color: #000;
}

.video-info {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.video-actions {
  margin-top: 10rpx;
}

.btn-small {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  background-color: #f0f0f0;
  color: #666;
  border-radius: 6rpx;
  margin-right: 10rpx;
}

.btn-small.delete {
  background-color: #ff4444;
  color: #fff;
}

/* 修改封面区域 */
.cover-modify-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.cover-preview {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background-color: #f5f5f5;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
}

.cover-label {
  font-size: 24rpx;
  color: #666;
}

/* 项目分类选择器 */
.category-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.category-tag-selected {
  flex: 0 0 auto;
  min-width: 0;
}

.category-tag-selected text {
  display: inline-block;
  font-size: 28rpx;
  color: #FF6B35;
  background-color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid #FF6B35;
}

.category-placeholder {
  flex: 1;
}

.category-placeholder text {
  font-size: 28rpx;
  color: #999;
}

.arrow-icon {
  font-size: 32rpx;
  color: #999;
  margin-left: 20rpx;
}

/* 表单行（门店和IP） */
.form-row {
  display: flex;
}

.form-col {
  flex: 1;
  min-width: 0;
}

.form-col:first-child {
  margin-right: 20rpx;
}

/* 合作金额 */
.amount-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.amount-input {
  flex: 1;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.amount-unit {
  font-size: 28rpx;
  color: #666;
  min-width: 40rpx;
}

.amount-separator {
  font-size: 32rpx;
  color: #999;
  margin: 0 10rpx;
}

/* 详情页图片网格 */
.detail-images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.detail-image-item {
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
  background-color: #f5f5f5;
  aspect-ratio: 1;
}

.detail-image-item::before {
  content: '';
  display: block;
  padding-bottom: 100%;
}

.detail-image-item > image {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
}

.detail-image-item.upload-item > view {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.delete-icon {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #ff4444;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.upload-item {
  border: 2rpx dashed #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-item .upload-icon-small {
  position: relative;
  z-index: 1;
}

.upload-icon-small {
  font-size: 60rpx;
  color: #999;
}

/* 入驻协议上传区域 */
.agreement-upload-area {
  margin-top: 20rpx;
}

.agreement-upload-btn {
  width: 100%;
  height: 300rpx;
  background-color: #f5f5f5;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.agreement-preview {
  position: relative;
}

.agreement-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 8rpx;
}

.agreement-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 20rpx;
}

/* 底部提交按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #FF6B35;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.submit-btn[disabled] {
  background-color: #ccc;
}

/* 项目分类选择器弹窗 */
.category-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.3s;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.category-picker-content {
  width: 100%;
  height: 70vh;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-cancel {
  font-size: 28rpx;
  color: #666;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-confirm {
  font-size: 28rpx;
  color: #1296db;
}

.picker-list {
  flex: 1;
  height: 50vh;
  min-height: 400rpx;
  padding: 20rpx 0;
}

.picker-item {
  padding: 30rpx;
  font-size: 28rpx;
  color: #666;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-item.selected {
  color: #FF6B35;
  font-weight: bold;
  background-color: #fff5f0;
}

.picker-item:last-child {
  border-bottom: none;
}
