<!--project-card.wxml-->
<view class="project-card" bindtap="onCardTap">
  <!-- 封面区域 -->
  <view class="cover-wrapper">
    <image wx:if="{{project.coverType === 'image' || project.coverType === 'carousel'}}" 
           class="cover-image" 
           src="{{project.coverUrl}}" 
           mode="aspectFill"></image>
    <view wx:if="{{project.coverType === 'video'}}" class="video-cover">
      <image class="cover-image" src="{{project.coverUrl}}" mode="aspectFill"></image>
      <!-- V6会员不支持视频，不显示播放图标和时长 -->
      <view wx:if="{{project.memberLevel !== 'V6'}}" class="play-icon"><view class="play-triangle"></view></view>
      <view wx:if="{{project.memberLevel !== 'V6'}}" class="duration">{{project.videoDuration}}</view>
    </view>
    <!-- 金盾认证徽章：只有V8会员支持金盾认证 -->
    <view wx:if="{{project.isOfficial && project.memberLevel === 'V8'}}" class="official-badge">金盾认证</view>
  </view>
  
  <!-- 内容信息 -->
  <view class="card-content">
    <!-- 标题 -->
    <view class="title">{{project.title}}</view>
    
    <!-- 信息行1：IP + 分类标签 + 门店数 -->
    <view class="info-row">
      <text class="ip">{{project.ip}}</text>
      <text class="category-tag">{{project.category}}</text>
      <text class="store-count">门店{{project.storeCount}}</text>
    </view>
    
    <!-- 信息行2：会员标签或平台认证标签 -->
    <view class="tag-row">
      <view wx:if="{{project.memberLevel}}" class="member-badge member-{{project.memberLevel}}">
        {{project.memberLevel}}
      </view>
      <!-- 闪电图标：V6会员专属图标，表示闪电发布，所有V6会员项目都显示 -->
      <image wx:if="{{project.memberLevel === 'V6'}}" class="member-tag" src="/images/icons/lightning.svg" mode="aspectFit"></image>
    </view>
    
    <!-- 底部信息：播放量 + 投资额 -->
    <view class="footer-info">
      <text class="view-count">播放量{{project.viewCount}}</text>
      <view class="investment-tag">投资额 {{project.investmentAmount}}</view>
    </view>
  </view>
</view>
