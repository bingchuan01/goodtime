/**data-dashboard.wxss**/
.data-dashboard {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 30rpx 20rpx;
  background-color: #fff;
  width: 100%;
  box-sizing: border-box;
}

.dashboard-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

/* 仅「战略合作」图标：明暗/透明度/轻微模糊的呼吸（真机可跑） */
@keyframes icon-breathe-dim {
  0%, 100% { opacity: 1; filter: brightness(1); }
  50% { opacity: 0.78; filter: brightness(0.88); }
}

.icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.icon-wrapper_breathe {
  animation: icon-breathe-dim 2.8s ease-in-out infinite;
}

.icon {
  width: 80rpx;
  height: 80rpx;
}

.icon-fallback {
  font-size: 48rpx;
  line-height: 48rpx;
}

.label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.value {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF6B35;
}
