/**data-dashboard.wxss**/
.data-dashboard {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 30rpx 20rpx;
  background-color: #fff;
  width: 100%;
  box-sizing: border-box;
}

.dashboard-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.icon {
  width: 48rpx;
  height: 48rpx;
}

.icon-fallback {
  font-size: 48rpx;
  line-height: 48rpx;
}

.label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.value {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF6B35;
}
