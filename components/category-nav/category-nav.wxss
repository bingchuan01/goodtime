/**category-nav.wxss**/
/* 真机需固定高度，否则 scroll-view 可能不显示 */
.category-nav {
  width: 100%;
  height: 200rpx;
  white-space: nowrap;
  padding: 20rpx 0;
  background-color: #fff;
  box-sizing: border-box;
}

.category-track {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 100%;
  padding: 0 16rpx;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin: 0 20rpx;
  padding: 10rpx;
  flex-shrink: 0;
}

.icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.category-item.active .icon-wrapper {
  background-color: #FFF5F0;
}

.icon {
  width: 80rpx;
  height: 80rpx;
}

.icon-fallback {
  font-size: 48rpx;
  line-height: 48rpx;
}

.label {
  font-size: 24rpx;
  color: #666;
}

.category-item.active .label {
  color: #FF6B35;
  font-weight: bold;
}
