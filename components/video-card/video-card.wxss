.video-card {
  background-color: #fff;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.video-cover {
  position: relative;
  width: 100%;
  height: 422rpx;
  background-color: #000;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.duration {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  padding: 4rpx 10rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 20rpx;
  border-radius: 4rpx;
}

.play-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  font-size: 40rpx;
  color: #333;
}

.video-info {
  padding: 20rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 15rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.separator {
  margin: 0 10rpx;
}

.stats {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.stat {
  margin-right: 30rpx;
}






